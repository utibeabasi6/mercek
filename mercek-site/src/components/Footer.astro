---
const year = 2026;
const cols = [
  {
    title: "product",
    links: [
      { href: "/#features", label: "Features" },
      { href: "/#agent", label: "Agent panel" },
      { href: "/#sentinel", label: "Sentinel" },
      { href: "/#install", label: "Download" },
    ],
  },
  {
    title: "resources",
    links: [
      { href: "/docs", label: "Docs" },
      { href: "https://github.com/utibeabasi6/mercek", label: "GitHub" },
      { href: "/llms.txt", label: "llms.txt" },
    ],
  },
];
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-xs">
        <div class="flex items-center gap-2 text-fg">
          <span
            class="grid size-6 place-items-center rounded-[6px] border border-line bg-elev text-accent"
            aria-hidden="true"
          >
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.6"></circle>
              <circle cx="8" cy="8" r="1.8" fill="currentColor"></circle>
            </svg>
          </span>
          <span class="text-[15px] font-semibold tracking-tight">mercek</span>
        </div>
        <p class="mt-3 text-[13px] leading-relaxed text-muted">
          A local-first desktop IDE for Amazon ECS. Runs on your machine with your
          own AWS credentials. Open source.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:gap-16">
        {cols.map((c) => (
          <div>
            <h3 class="text-[11px] uppercase tracking-widest text-muted">{c.title}</h3>
            <ul class="mt-3 space-y-2">
              {c.links.map((l) => (
                <li>
                  <a href={l.href} class="text-[13px] text-dim transition-colors hover:text-fg">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-line pt-6 text-[12px] text-muted sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} Mercek. Not affiliated with Amazon Web Services.</span>
      <span>ECS, Fargate, CloudWatch, and ECR are trademarks of Amazon.com, Inc.</span>
    </div>
  </div>
</footer>
