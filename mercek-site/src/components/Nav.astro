---
const links = [
  { href: "/#features", label: "features" },
  { href: "/#agent", label: "agent" },
  { href: "/#sentinel", label: "sentinel" },
  { href: "/#security", label: "local-first" },
  { href: "/#install", label: "download" },
];
---

<header
  class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur supports-[backdrop-filter]:bg-bg/60"
>
  <nav class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="group flex items-center gap-2 text-fg" aria-label="Mercek home">
      <span
        class="grid size-6 place-items-center rounded-[6px] border border-line bg-elev text-accent"
        aria-hidden="true"
      >
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.6"></circle>
          <circle cx="8" cy="8" r="1.8" fill="currentColor"></circle>
        </svg>
      </span>
      <span class="text-[15px] font-semibold tracking-tight">mercek</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class="text-[13px] text-dim transition-colors hover:text-fg"
        >
          {l.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/utibeabasi6/mercek"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Star Mercek on GitHub"
        class="flex items-center gap-1.5 rounded-md border border-line px-2.5 py-1.5 text-[13px] text-dim transition-colors hover:text-fg"
      >
        <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
        </svg>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true">
          <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z" />
        </svg>
        <span id="gh-stars" class="tabular-nums"></span>
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
        class="grid size-8 place-items-center rounded-md border border-line text-dim transition-colors hover:text-fg"
      >
        <svg class="hidden dark-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="hidden light-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
      <a
        href="/#install"
        class="rounded-md bg-accent px-3 py-1.5 text-[13px] font-semibold text-bg transition-opacity hover:opacity-90"
      >
        Download
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    function sync() {
      var dark = document.documentElement.getAttribute("data-theme") !== "light";
      var d = btn.querySelector(".dark-icon");
      var l = btn.querySelector(".light-icon");
      // Show the icon for the theme you'd switch TO.
      if (d) d.classList.toggle("hidden", dark);
      if (l) l.classList.toggle("hidden", !dark);
    }
    btn.addEventListener("click", function () {
      var next =
        document.documentElement.getAttribute("data-theme") === "light"
          ? "dark"
          : "light";
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("mercek-theme", next);
      } catch (e) {}
      sync();
    });
    sync();
  })();
</script>

<script is:inline>
  // Live GitHub star count, filled client-side so it updates without a rebuild.
  // Degrades to just the GitHub + star icons if the repo is private or the API fails.
  fetch("https://api.github.com/repos/utibeabasi6/mercek")
    .then(function (r) {
      return r.ok ? r.json() : null;
    })
    .then(function (d) {
      if (!d || typeof d.stargazers_count !== "number") return;
      var n = d.stargazers_count;
      var s = n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(n);
      var el = document.getElementById("gh-stars");
      if (el) el.textContent = s;
    })
    .catch(function () {});
</script>
