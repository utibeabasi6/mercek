---
/*
  A slot for a real product screenshot. Until the image exists it renders a
  labeled placeholder; once you drop the file in public/screenshots/, pass `src`
  (e.g. src="/screenshots/hero.png") and it renders the image instead.
  See mercek-site/SCREENSHOTS.md for the shot list.
*/
interface Props {
  label: string; // what to capture (also used as alt text)
  file: string; // suggested filename under public/screenshots/
  ratio?: string; // tailwind aspect-ratio class
  src?: string; // set once the screenshot exists
}
const { label, file, ratio = "aspect-[16/10]", src } = Astro.props;
---

{
  src ? (
    <img
      src={src}
      alt={label}
      loading="lazy"
      class="w-full rounded-xl border border-line shadow-xl shadow-black/20"
    />
  ) : (
    <div
      class={`relative w-full ${ratio} overflow-hidden rounded-xl border border-dashed border-line bg-elev/40`}
    >
      <div class="absolute inset-0 grid place-items-center p-6 text-center">
        <div>
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            class="mx-auto text-muted"
          >
            <rect x="3" y="4" width="18" height="14" rx="2" />
            <path d="M3 14l4-4 4 4 3-3 4 4" />
            <circle cx="9" cy="9" r="1.2" fill="currentColor" stroke="none" />
          </svg>
          <div class="mt-3 text-[12px] text-dim">{label}</div>
          <div class="mt-1 font-mono text-[11px] text-muted">/screenshots/{file}</div>
        </div>
      </div>
    </div>
  )
}
